"""Environment configuration example file."""

# Application
APP_NAME=telegram-accounts-marketplace
DEBUG=False
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/marketplace_db
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Admin IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Telethon Configuration
TELETHON_API_ID=your_api_id
TELETHON_API_HASH=your_api_hash
TELETHON_SESSION_DIR=./sessions

# CryptoBot Payment
CRYPTOBOT_API_TOKEN=your_cryptobot_token
CRYPTOBOT_SHOP_ID=your_shop_id
CRYPTOBOT_WEBHOOK_SECRET=your_webhook_secret
CRYPTOBOT_API_URL=https://pay.crypt.bot/api

# TON Keeper Payment
TON_WALLET_ADDRESS=your_ton_wallet_address
TON_MNEMONIC=
TON_RPC_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TON_NETWORK=testnet
TON_WATCH_INTERVAL=30

# Telegram Stars
TELEGRAM_STARS_ENABLED=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_WEBHOOK_URL=https://your-domain.com/webhooks/

# Session Encryption
SESSION_ENCRYPTION_KEY=your_32_char_encryption_key_here

# Order Configuration
ORDER_RESERVATION_TTL=3600
ORDER_PAYMENT_TIMEOUT=1800
AUTO_CANCEL_ORDER_HOURS=24

# Cleanup Configuration
CLEANUP_RETRY_INTERVAL=1800
CLEANUP_MAX_RETRIES=10

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60

# Anti-spam
FLOOD_THRESHOLD=5
FLOOD_BLOCK_DURATION=600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# CORS Settings
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Sentry (Optional)
SENTRY_DSN=

# Webhook Security
WEBHOOK_SECRET=your_webhook_secret_key
WEBHOOK_TIMEOUT=30

# Payment Methods (Enable/Disable)
PAYMENT_METHOD_CRYPTOBOT=True
PAYMENT_METHOD_TON=True
PAYMENT_METHOD_STARS=True

# Notifications
NOTIFICATIONS_ENABLED=True
NOTIFICATION_CHAT_ID=your_notification_chat_id

# Metrics
METRICS_ENABLED=False
METRICS_PORT=9090
